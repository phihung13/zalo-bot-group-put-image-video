# ====== Mẫu biến môi trường ======
# Copy file này thành .env rồi điền giá trị thật. KHÔNG commit .env.
# Trên VPS/Coolify: đặt các biến này trong tab Environment Variables.

# --- Bắt buộc ---
FB_APP_ID=
FB_APP_SECRET=
DASHBOARD_USER=admin
DASHBOARD_PASS=doi-mat-khau-manh

# --- Claude AI (có thể cấp qua dashboard tab Cài đặt thay vì đặt ở đây) ---
# ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Tùy chọn ---
WEB_PORT=8080
FB_GRAPH_VERSION=v21.0

# --- Token TỪNG Trang Facebook: KHÔNG đặt ở đây ---
# Cấp qua dashboard (tab Token) -> hệ thống tự lưu vào data/tokens.json.
# Ví dụ tên biến nếu muốn đặt tay: FB_PAGE_TOKEN_VIETANH=...
